# ===========================================================================
# Industrial Knowledge Brain — backend environment
# Copy to .env and fill in. Never commit the real .env.
# ===========================================================================

# ---- App ----
APP_NAME=Industrial Knowledge Brain
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (the JSX frontend dev/prod URLs)
# Add your Vercel deployment URL here once deployed
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://indusmind-1.vercel.app,https://*.vercel.app

# ---- Auth ----
# Set AUTH_ENABLED=false to run locally without Supabase (returns a dev admin).
AUTH_ENABLED=true

# ---- Supabase (hosted) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_BUCKET=documents

# ---- Database (Supabase Postgres, async driver) ----
# Supabase → Project Settings → Database → Connection string (URI).
# Replace the scheme with postgresql+asyncpg:// for the async driver.
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---- Gemini ----
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ---- Embeddings ----
# gemini | huggingface | mock  (mock = deterministic offline vectors, no key)
# Vectors are stored in Supabase pgvector; the column is fixed at EMBEDDING_DIM.
# All options below produce 768-d vectors. Switching providers needs a re-index.
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIM=768

# Hugging Face Inference API (only used when EMBEDDING_PROVIDER=huggingface).
# Create a token at https://huggingface.co/settings/tokens WITH the
# "Make calls to Inference Providers" permission enabled, or calls return 403.
HF_API_TOKEN=
HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Embeddings are generated in batches (one request per N chunks) to speed up
# ingestion. Lower it if you hit provider payload limits.
EMBEDDING_BATCH_SIZE=64

# ---- Chunking / retrieval ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=10

# ---- OCR (heavy; off by default) ----
ENABLE_OCR=false

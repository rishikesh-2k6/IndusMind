# Frontend environment (Vite). Copy to .env.local for local dev.
# On Vercel, set these as Environment Variables in the project dashboard.
# These are exposed to the browser, so use the Supabase ANON key only.

# Backend API base URL.
# - Local dev: http://localhost:8000
# - Vercel (same-origin /api function): leave UNSET or set to "" — the app then
#   makes relative requests to /api/* which Vercel routes to the Python function.
VITE_API_URL=http://localhost:8000

# Supabase (same project as the backend)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
